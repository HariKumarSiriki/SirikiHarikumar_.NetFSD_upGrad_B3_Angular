@model List<Product>

<h2>Product List</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Price</th>
            <th>Category</th>
            <th>Action</th>
           
        </tr>
    </thead>

    <tbody>
        @foreach (Product p in Model)
        {
            <tr>
                <td>@p.Id</td>
                <td>@p.Name</td>
                <td>@p.Price</td>
                <td>@p.Category</td>
              <td><a asp-action="Details" asp-route-id="@p.Id">View</a></td>
            </tr>
        }
    </tbody>
</table>
