<div class="container mt-5">
    <h3>Feedback Form</h3>

    <form method="post" class="card p-4 shadow">

        @if (ViewData["Error"] != null)
        {
            <div class="alert alert-danger">@ViewData["Error"]</div>
        }

        @if (ViewData["Message"] != null)
        {
            <div class="alert alert-success">@ViewData["Message"]</div>
        }

        <input type="text" name="name" class="form-control mb-2" placeholder="Name" />
        <textarea name="comments" class="form-control mb-2" placeholder="Comments"></textarea>
        <input type="number" name="rating" class="form-control mb-2" placeholder="Rating (1-5)" />

        <button class="btn btn-success">Submit</button>
    </form>
</div>
