@model List<WebApplication1.Models.Movie>

<h2>Movies</h2>

<a href="/Movies/Create" class="btn btn-primary">Add Movie</a>

<table class="table mt-3">
    <tr>
        <th>Title</th>
        <th>Genre</th>
        <th>Price</th>
        <th>Actions</th>
    </tr>

    @foreach (var m in Model)
    {
        <tr>
            <td>@m.Title</td>
            <td>@m.Genre</td>
            <td>@m.Price</td>
            <td>
                <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-warning btn-sm">Edit</a>
                <a asp-action="Details" asp-route-id="@m.Id" class="btn btn-info btn-sm">Details</a>
                <a asp-action="Delete" asp-route-id="@m.Id" class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
    }
</table>
