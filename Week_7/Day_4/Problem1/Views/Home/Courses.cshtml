@model List<WebApplication3.Models.Course>

<div class="container mt-4">

  
    <div class="card p-4 shadow-sm mb-4">
        <h4 class="text-primary">Add Course</h4>

        <form method="post">
            <div class="mb-3">
                <label class="form-label">Course Name</label>
                <input type="text" name="CourseName" class="form-control" placeholder="Enter course name" />
            </div>

            <button type="submit" class="btn btn-success">Add Course</button>
        </form>
    </div>


  
    <div class="card p-4 shadow-sm">
        <h3 class="mb-3 text-primary">Courses List</h3>

        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Course Id</th>
                    <th>Course Name</th>
                    <th>Students</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CourseId</td>
                        <td>@item.CourseName</td>
                        <td>
                            <ul>
                                @foreach (var std in item.Students)
                                {
                                    <li>@std.StudentName</li>
                                }
                            </ul>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>