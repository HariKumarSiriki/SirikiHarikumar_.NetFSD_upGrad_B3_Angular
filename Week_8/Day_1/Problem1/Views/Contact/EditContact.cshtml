@model WebApplication4.Models.ContactInfo

<h2>Edit Contact</h2>

<form asp-action="EditContact" method="post">

    <input type="hidden" asp-for="ContactId" />

    <label>First Name</label>
    <input asp-for="FirstName" class="form-control" />

    <label>Last Name</label>
    <input asp-for="LastName" class="form-control" />

    <label>Email</label>
    <input asp-for="EmailId" class="form-control" />

    <label>Mobile</label>
    <input asp-for="MobileNo" class="form-control" />

    <label>Designation</label>
    <input asp-for="Designation" class="form-control" />

    <!-- Company Dropdown -->
    <label>Company</label>
    <select asp-for="CompanyId" class="form-control">
        @foreach (var c in ViewBag.Companies)
        {
            <option value="@c.CompanyId" selected="@(c.CompanyId == Model.CompanyId)">
                @c.CompanyName
            </option>
        }
    </select>

    <!-- Department Dropdown -->
    <label>Department</label>
    <select asp-for="DepartmentId" class="form-control">
        @foreach (var d in ViewBag.Departments)
        {
            <option value="@d.DepartmentId" selected="@(d.DepartmentId == Model.DepartmentId)">
                @d.DepartmentName
            </option>
        }
    </select>

    <br />

    <button type="submit" class="btn btn-success">Update</button>
</form>

<a asp-action="ShowContacts">Back</a>